{
  "name": "kostenfuchs",
  "version": "1.0.0",
  "description": "Simple Hello World Node.js app",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/style.css",
    "build:css:watch": "tailwindcss -i ./src/input.css -o ./public/style.css --watch",
    "start": "node dist/index.js",
    "dev": "concurrently \"nodemon\" \"npm run dev:css\"",
    "dev:css": "tailwindcss -i ./src/input.css -o ./public/style.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.0",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
